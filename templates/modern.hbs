<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{name}} - 简历</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      line-height: 1.6;
      color: #333;
      background: #fff;
    }
    
    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 40px;
    }
    
    /* Header */
    .header {
      text-align: center;
      padding-bottom: 30px;
      border-bottom: 2px solid #2c3e50;
      margin-bottom: 30px;
    }
    
    .name {
      font-size: 36px;
      font-weight: 700;
      color: #2c3e50;
      margin-bottom: 10px;
    }
    
    .title {
      font-size: 18px;
      color: #7f8c8d;
      margin-bottom: 15px;
    }
    
    .contact {
      display: flex;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
      font-size: 14px;
      color: #555;
    }
    
    .contact-item {
      display: flex;
      align-items: center;
      gap: 5px;
    }
    
    /* Section */
    .section {
      margin-bottom: 30px;
    }
    
    .section-title {
      font-size: 18px;
      font-weight: 600;
      color: #2c3e50;
      border-bottom: 2px solid #3498db;
      padding-bottom: 8px;
      margin-bottom: 15px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    
    /* Summary */
    .summary {
      font-size: 15px;
      line-height: 1.8;
      color: #555;
    }
    
    /* Skills */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
    }
    
    .skill-category {
      background: #f8f9fa;
      padding: 12px 15px;
      border-radius: 6px;
    }
    
    .skill-category-name {
      font-weight: 600;
      color: #2c3e50;
      margin-bottom: 8px;
      font-size: 13px;
      text-transform: uppercase;
    }
    
    .skill-list {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    
    .skill-tag {
      background: #3498db;
      color: white;
      padding: 3px 10px;
      border-radius: 12px;
      font-size: 12px;
    }
    
    /* Experience */
    .experience-item {
      margin-bottom: 25px;
    }
    
    .experience-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
    }
    
    .company {
      font-size: 17px;
      font-weight: 600;
      color: #2c3e50;
    }
    
    .duration {
      font-size: 13px;
      color: #7f8c8d;
      font-style: italic;
    }
    
    .position {
      font-size: 15px;
      color: #3498db;
      margin-bottom: 8px;
    }
    
    .description {
      font-size: 14px;
      color: #555;
      margin-bottom: 10px;
    }
    
    .achievements {
      list-style: none;
      padding-left: 0;
    }
    
    .achievements li {
      position: relative;
      padding-left: 20px;
      margin-bottom: 5px;
      font-size: 14px;
      color: #555;
    }
    
    .achievements li::before {
      content: '▸';
      position: absolute;
      left: 0;
      color: #3498db;
    }
    
    /* Education */
    .education-item {
      margin-bottom: 15px;
    }
    
    .school {
      font-size: 16px;
      font-weight: 600;
      color: #2c3e50;
    }
    
    .degree {
      font-size: 14px;
      color: #555;
    }
    
    /* Projects */
    .project-item {
      margin-bottom: 20px;
    }
    
    .project-name {
      font-size: 16px;
      font-weight: 600;
      color: #2c3e50;
      margin-bottom: 5px;
    }
    
    .project-desc {
      font-size: 14px;
      color: #555;
      margin-bottom: 8px;
    }
    
    .project-tech {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    
    .tech-tag {
      background: #ecf0f1;
      color: #2c3e50;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 12px;
    }
    
    /* Footer */
    .footer {
      text-align: center;
      padding-top: 20px;
      border-top: 1px solid #ecf0f1;
      font-size: 12px;
      color: #95a5a6;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <header class="header">
      <h1 class="name">{{name}}</h1>
      <p class="title">{{title}}</p>
      <div class="contact">
        {{#if email}}
        <span class="contact-item">📧 {{email}}</span>
        {{/if}}
        {{#if phone}}
        <span class="contact-item">📱 {{phone}}</span>
        {{/if}}
        {{#if location}}
        <span class="contact-item">📍 {{location}}</span>
        {{/if}}
        {{#if website}}
        <span class="contact-item">🌐 {{website}}</span>
        {{/if}}
      </div>
    </header>
    
    <!-- Summary -->
    {{#if summary}}
    <section class="section">
      <h2 class="section-title">个人简介</h2>
      <p class="summary">{{summary}}</p>
    </section>
    {{/if}}
    
    <!-- Skills -->
    {{#if skillsByCategory}}
    <section class="section">
      <h2 class="section-title">专业技能</h2>
      <div class="skills-grid">
        {{#each skillsByCategory}}
        <div class="skill-category">
          <div class="skill-category-name">{{@key}}</div>
          <div class="skill-list">
            {{#each this}}
            <span class="skill-tag">{{this}}</span>
            {{/each}}
          </div>
        </div>
        {{/each}}
      </div>
    </section>
    {{/if}}
    
    <!-- Experience -->
    {{#if experience}}
    <section class="section">
      <h2 class="section-title">工作经历</h2>
      {{#each experience}}
      <div class="experience-item">
        <div class="experience-header">
          <span class="company">{{company}}</span>
          <span class="duration">{{duration}}</span>
        </div>
        <div class="position">{{position}}</div>
        {{#if description}}
        <p class="description">{{description}}</p>
        {{/if}}
        {{#if achievements}}
        <ul class="achievements">
          {{#each achievements}}
          <li>{{this}}</li>
          {{/each}}
        </ul>
        {{/if}}
      </div>
      {{/each}}
    </section>
    {{/if}}
    
    <!-- Education -->
    {{#if education}}
    <section class="section">
      <h2 class="section-title">教育背景</h2>
      {{#each education}}
      <div class="education-item">
        <div class="school">{{school}}</div>
        <div class="degree">{{degree}} {{#if duration}}| {{duration}}{{/if}}</div>
      </div>
      {{/each}}
    </section>
    {{/if}}
    
    <!-- Projects -->
    {{#if projects}}
    <section class="section">
      <h2 class="section-title">项目经历</h2>
      {{#each projects}}
      <div class="project-item">
        <div class="project-name">{{name}}</div>
        <p class="project-desc">{{description}}</p>
        {{#if techStack}}
        <div class="project-tech">
          {{#each techStack}}
          <span class="tech-tag">{{this}}</span>
          {{/each}}
        </div>
        {{/if}}
      </div>
      {{/each}}
    </section>
    {{/if}}
    
    <!-- Footer -->
    <footer class="footer">
      <p>Generated by Resume Generator | {{yearsOfExperience}} 年工作经验</p>
    </footer>
  </div>
</body>
</html>
