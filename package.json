{
  "name": "resume-generator",
  "version": "1.0.0",
  "description": "AI 驱动的简历生成器 - 自动生成专业简历",
  "main": "src/index.js",
  "bin": {
    "resume-gen": "./src/cli.js",
    "简历生成器": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js create",
    "dev": "nodemon src/cli.js",
    "build": "node scripts/build.js",
    "build:win": "pkg . --targets node18-win-x64 --output dist/resume-generator.exe --compress GZip",
    "build:win:gui": "cd gui && npm run build:win",
    "build:all": "npm run build:win && npm run build:win:gui",
    "test": "jest",
    "pkg:install": "npm install -g pkg",
    "dist": "npm run build:win && node scripts/package-windows.js"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "assets": [
      "templates/**/*",
      "examples/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "resume",
    "cv",
    "generator",
    "ai",
    "markdown",
    "pdf",
    "简历",
    "生成器"
  ],
  "author": "CNMJH",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.0.0",
    "marked": "^9.0.0",
    "puppeteer": "^21.0.0",
    "handlebars": "^4.7.8",
    "chalk": "^4.1.2",
    "inquirer": "^8.2.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "jest": "^29.0.0",
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CNMJH/resume-generator.git"
  },
  "bugs": {
    "url": "https://github.com/CNMJH/resume-generator/issues"
  },
  "homepage": "https://github.com/CNMJH/resume-generator#readme"
}
